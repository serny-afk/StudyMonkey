{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend/src/main.ts",
      "routePrefix": "/api",
      "framework": "nestjs",
      "includeFiles": [
        "backend/node_modules/pg/**"
      ]
    }
  }
}
